# Grobogan Worker Configuration
# ── Copy to .env and fill in your values ──

# ═══════════════════════════════════════════════════════════════════════
#  Manager connection
# ═══════════════════════════════════════════════════════════════════════
# URL where the Socket.IO manager server is running.
# Supports WebSocket upgrade via Cloudflare Tunnel / reverse proxy.
#
#   Local dev:  http://localhost:8080
#   Remote IP:  http://203.0.113.10:8080
#   Domain:     https://va-grob.nael.my.id
MANAGER_URL=http://localhost:8080

# ═══════════════════════════════════════════════════════════════════════
#  Worker identity
# ═══════════════════════════════════════════════════════════════════════
# Leave empty for auto-generated persistent ID (stored in .worker-id)
WORKER_ID=

# Display name in dashboard.  Empty = auto-detect system hostname.
HOSTNAME=

# Set "auto" for auto-detection, or specify a static IP.
IP=auto

# ═══════════════════════════════════════════════════════════════════════
#  Security
# ═══════════════════════════════════════════════════════════════════════
# Auth token — MUST match the manager's WORKER_TOKEN.  Change in production!
WORKER_TOKEN=change_me_to_a_secure_token

# ═══════════════════════════════════════════════════════════════════════
#  Capabilities (tools the worker can execute)
# ═══════════════════════════════════════════════════════════════════════
# Lightweight:  nmap,nikto,gobuster,sqlmap,curl,jq,sslscan,whatweb,dig
# Full suite:   nmap,nikto,gobuster,sqlmap,curl,jq,masscan,dnsrecon,hydra,sslscan,amass,dirb,whatweb,testssl
# Discovery:    nmap,dig,curl,jq
CAPABILITIES=nmap,nikto,gobuster,sqlmap,curl,jq

# ═══════════════════════════════════════════════════════════════════════
#  Timing (milliseconds)
# ═══════════════════════════════════════════════════════════════════════
HEARTBEAT_INTERVAL=30000
TASK_REQUEST_INTERVAL=5000

# ═══════════════════════════════════════════════════════════════════════
#  Concurrency
# ═══════════════════════════════════════════════════════════════════════
MAX_CONCURRENT_TASKS=2

# ═══════════════════════════════════════════════════════════════════════
#  Quick start
# ═══════════════════════════════════════════════════════════════════════
#   1. ./deploy.sh              — install deps + build
#   2. Edit this file           — set MANAGER_URL, WORKER_TOKEN
#   3. ./start.sh               — run in background
#   4. ./stop.sh                — stop
#   5. ./install-service.sh     — systemd service (auto-start on boot)
