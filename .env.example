# Grobogan Worker Configuration

# ── Manager connection ──
# URL where the Socket.IO manager server is running.
# Can be local or remote (IP, domain, Cloudflare Tunnel).
# Examples:
#   Local:    http://localhost:8080
#   Remote:   http://203.0.113.10:8080
#   Domain:   https://va-grob.nael.my.id
MANAGER_URL=http://localhost:8080

# ── Worker identification ──
WORKER_ID=
# Leave empty for auto-generated persistent ID
HOSTNAME=
# Leave empty to auto-detect
IP=auto

# ── Security ──
# Auth token — must match the manager's WORKER_TOKEN
WORKER_TOKEN=change_me_to_a_secure_token

# ── Capabilities ──
# Comma-separated list of tools the worker can execute.
# Standard: nmap,nikto,gobuster,sqlmap,curl,jq
# Kali:     nmap,nikto,gobuster,sqlmap,curl,jq,masscan,dnsrecon,hydra,sslscan,amass,dirb,whatweb,testssl
CAPABILITIES=nmap,nikto,gobuster,sqlmap,curl,jq

# ── Timing ──
HEARTBEAT_INTERVAL=30000
TASK_REQUEST_INTERVAL=5000

# ── Concurrency ──
MAX_CONCURRENT_TASKS=1
